<?xml version="1.0" encoding="UTF-8"?>
<!--
  LanOnasis Sitemap Template
  Replace {{DOMAIN}} with your full domain (e.g. https://lanonasis.com)
  Replace {{LASTMOD}} with ISO date (e.g. 2026-03-29)
  Remove or adjust entries that don't apply to your site.

  Priorities:
    1.0 — Homepage
    0.9 — Primary landing pages (features, pricing)
    0.8 — Secondary pages (about, docs index)
    0.7 — Blog index, category pages
    0.5 — Individual blog posts, changelog entries
    0.3 — Legal pages (privacy, terms)

  changefreq:
    always   — content changes on every visit (avoid — misleads crawlers)
    hourly   — live dashboards, news tickers
    daily    — blog, changelog
    weekly   — docs, product pages
    monthly  — marketing pages
    yearly   — legal pages
    never    — archived/static content
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.sitemaps.org/schemas/sitemap/0.9
          http://www.sitemaps.org/schemas/sitemap/0.9/sitemap.xsd">

  <!-- ==================== CORE PAGES ==================== -->

  <url>
    <loc>{{DOMAIN}}/</loc>
    <lastmod>{{LASTMOD}}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>

  <!-- ==================== PRODUCT / FEATURES ==================== -->

  <url>
    <loc>{{DOMAIN}}/features</loc>
    <lastmod>{{LASTMOD}}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.9</priority>
  </url>

  <url>
    <loc>{{DOMAIN}}/pricing</loc>
    <lastmod>{{LASTMOD}}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.9</priority>
  </url>

  <!-- ==================== ABOUT / COMPANY ==================== -->

  <url>
    <loc>{{DOMAIN}}/about</loc>
    <lastmod>{{LASTMOD}}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>

  <url>
    <loc>{{DOMAIN}}/contact</loc>
    <lastmod>{{LASTMOD}}</lastmod>
    <changefreq>yearly</changefreq>
    <priority>0.7</priority>
  </url>

  <!-- ==================== BLOG / CHANGELOG ==================== -->
  <!-- Uncomment and duplicate for each post -->
  <!--
  <url>
    <loc>{{DOMAIN}}/blog</loc>
    <lastmod>{{LASTMOD}}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
  </url>

  <url>
    <loc>{{DOMAIN}}/blog/your-post-slug</loc>
    <lastmod>{{LASTMOD}}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
  </url>
  -->

  <!-- ==================== LEGAL ==================== -->

  <url>
    <loc>{{DOMAIN}}/privacy</loc>
    <lastmod>{{LASTMOD}}</lastmod>
    <changefreq>yearly</changefreq>
    <priority>0.3</priority>
  </url>

  <url>
    <loc>{{DOMAIN}}/terms</loc>
    <lastmod>{{LASTMOD}}</lastmod>
    <changefreq>yearly</changefreq>
    <priority>0.3</priority>
  </url>

</urlset>
